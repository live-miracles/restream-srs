{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "strict": true,
        "outDir": "public/js",
        "rootDir": "public/ts",
        "skipLibCheck": true,
        "noEmitOnError": true
    },
    "include": ["public/ts/**/*.ts"]
}
