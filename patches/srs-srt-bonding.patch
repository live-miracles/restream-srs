# SRS: Enable SRT Connection Bonding (listener/receiver side)
#
# Target: SRS v6.0-r0
# Apply:  cd srs && patch -p1 < patches/srs-srt-bonding.patch
#
# What this does:
#   1. Enables ENABLE_BONDING in the libsrt build (already bundled at v1.5.3)
#   2. Sets SRTO_GROUPCONNECT on the listener socket so bonded callers
#      are accepted instead of rejected
#   3. Fixes srs_srt_get_remote_ip_port to use srt_group_data() for group IDs
#      (srt_getpeername does not handle group IDs)
#   4. Switches srt_recvmsg/srt_sendmsg to srt_recvmsg2/srt_sendmsg2
#      which work transparently with both socket IDs and group IDs
#   5. Adds logging when a bonded group connection is accepted
#
# How it works:
#   libsrt handles all the complexity internally. When a bonded caller
#   (e.g. an encoder with SRT bonding enabled) connects multiple
#   sockets over different network paths, libsrt creates a "mirror group"
#   on the listener side. srt_accept() returns the group ID for the first
#   member. Subsequent members are added automatically. Reading from the
#   group ID with srt_recvmsg2() deduplicates data across all links.
#
# Note on the #ifdef guard:
#   SRTO_GROUPCONNECT is used as the guard. It is always defined in libsrt's
#   public srt.h (unconditionally, as part of the enum), so the guarded code
#   is always compiled in. The actual bonding runtime behaviour requires
#   libsrt to be built with --enable-bonding=1, which is set in depends.sh.
#
# Testing:
#   1. Build SRS: bash scripts/build-srs.sh
#   2. Configure your encoder for SRT bonding output
#   3. Point both bonded paths to SRS's SRT listener (same host:port:streamid)
#   4. Verify with: ffprobe srt://srs-host:10080?streamid=...
#   5. Kill one network path - stream should continue without interruption
#
# No external library changes needed. Uses the libsrt already bundled in SRS.
#
diff --git a/trunk/auto/depends.sh b/trunk/auto/depends.sh
index bfc9a08..6595d84 100755
--- a/trunk/auto/depends.sh
+++ b/trunk/auto/depends.sh
@@ -670,7 +670,7 @@ if [[ $SRS_SRT == YES && $SRS_USE_SYS_SRT == NO ]]; then
 fi
 if [[ $SRS_SRT == YES && $SRS_USE_SYS_SRT == NO ]]; then
     # Always disable c++11 for libsrt, because only the srt-app requres it.
-    LIBSRT_OPTIONS="--enable-apps=0  --enable-static=1 --enable-c++11=0"
+    LIBSRT_OPTIONS="--enable-apps=0  --enable-static=1 --enable-c++11=0 --enable-bonding=1"
     CMAKE_VERSION=$(cmake --version | head -n1 | cut -d' ' -f3)
     CMAKE_MAJOR=$(echo $CMAKE_VERSION | cut -d'.' -f1)
     if [[ $CMAKE_MAJOR -ge 4 ]]; then
diff --git a/trunk/src/protocol/srs_protocol_srt.cpp b/trunk/src/protocol/srs_protocol_srt.cpp
index b85c76b..4a09dbd 100644
--- a/trunk/src/protocol/srs_protocol_srt.cpp
+++ b/trunk/src/protocol/srs_protocol_srt.cpp
@@ -199,6 +199,15 @@ srs_error_t srs_srt_socket_with_default_option(srs_srt_t *pfd)
         return srs_error_wrap(err, "set latency");
     }

+#ifdef SRTO_GROUPCONNECT
+    // Enable acceptance of bonded group connections (SRT v1.5+).
+    // When a bonded caller connects, srt_accept() returns a group ID
+    // instead of a socket ID. The group ID works transparently with
+    // srt_recvmsg2() for reading -- libsrt handles deduplication internally.
+    int group_connect = 1;
+    SET_SRT_OPT(srt_fd, SRTO_GROUPCONNECT, group_connect);
+#endif
+
     *pfd = srt_fd;

     return err;
@@ -434,8 +443,21 @@ srs_error_t srs_srt_get_remote_ip_port(srs_srt_t srt_fd, std::string& ip, int& port)
     // discovery client information
     sockaddr_storage addr;
     int addrlen = sizeof(addr);
-    if (srt_getpeername(srt_fd, (sockaddr*)&addr, &addrlen) == -1) {
-        return srs_error_new(ERROR_SRT_SOCKOPT, "srt_getpeername");
-    }
+#ifdef SRTO_GROUPCONNECT
+    // srt_getpeername does not handle group IDs -- use srt_group_data to get
+    // the peer address from the first member socket of the bonded group.
+    if (srt_fd & SRTGROUP_MASK) {
+        size_t count = 1;
+        SRT_SOCKGROUPDATA gdata[1];
+        if (srt_group_data(srt_fd, gdata, &count) == SRT_ERROR || count == 0) {
+            return srs_error_new(ERROR_SRT_SOCKOPT, "srt_group_data");
+        }
+        memcpy(&addr, &gdata[0].peeraddr, sizeof(addr));
+        addrlen = (addr.ss_family == AF_INET) ? sizeof(sockaddr_in) : sizeof(sockaddr_in6);
+    } else
+#endif
+    if (srt_getpeername(srt_fd, (sockaddr*)&addr, &addrlen) == -1) {
+        return srs_error_new(ERROR_SRT_SOCKOPT, "srt_getpeername");
+    }
 
     char saddr[64];
@@ -790,6 +799,14 @@ srs_error_t SrsSrtSocket::accept(srs_srt_t *client_srt_fd)

         // Accept ok, return with the SRT client fd.
         if (srt_fd != srs_srt_socket_invalid()) {
+#ifdef SRTO_GROUPCONNECT
+            // With SRTO_GROUPCONNECT enabled, srt_accept() may return a group ID
+            // (high bit set) for bonded connections. The ID works transparently
+            // with srt_recvmsg2/srt_sendmsg2 -- libsrt deduplicates internally.
+            if (srt_fd & SRTGROUP_MASK) {
+                srs_trace("SRT: accepted bonded group, group_id=0x%x", srt_fd);
+            }
+#endif
             *client_srt_fd = srt_fd;
             return err;
         }
@@ -813,8 +830,10 @@ srs_error_t SrsSrtSocket::recvmsg(void *buf, size_t size, ssize_t *nread)
     srs_error_t err = srs_success;

     while (true) {
-        // @see https://github.com/Haivision/srt/blob/master/docs/API/API-functions.md#srt_recvmsg
-        int ret = srt_recvmsg(srt_fd_, (char*)buf, size);
+        // @see https://github.com/Haivision/srt/blob/master/docs/API/API-functions.md#srt_recvmsg2
+        // Use srt_recvmsg2 which works with both individual sockets and bonded groups.
+        SRT_MSGCTRL mc = srt_msgctrl_default;
+        int ret = srt_recvmsg2(srt_fd_, (char*)buf, size, &mc);

         // Receive message ok.
         if (ret >= 0) {
@@ -842,8 +861,10 @@ srs_error_t SrsSrtSocket::sendmsg(void *buf, size_t size, ssize_t *nwrite)
     srs_error_t err = srs_success;

     while (true) {
-        // @see https://github.com/Haivision/srt/blob/master/docs/API/API-functions.md#srt_sendmsg
-        int ret = srt_sendmsg(srt_fd_, (const char*)buf, size, -1, 1);
+        // @see https://github.com/Haivision/srt/blob/master/docs/API/API-functions.md#srt_sendmsg2
+        // Use srt_sendmsg2 which works with both individual sockets and bonded groups.
+        SRT_MSGCTRL mc = srt_msgctrl_default;
+        int ret = srt_sendmsg2(srt_fd_, (const char*)buf, size, &mc);

         // Send message ok.
         if (ret >= 0) {
