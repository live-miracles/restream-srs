{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "lib": ["ES2022"],
        "strict": true,
        "outDir": "dist",
        "rootDir": "src",
        "skipLibCheck": true,
        "noEmitOnError": true,
        "esModuleInterop": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "public"]
}
